{
  "locale": {
    "source": "en",
    "targets": ["sv"]
  },
  "compiler": {
    "framework": "react",
    "entry": "src/index.tsx",
    "outputDir": "src/localized",
    "include": [
      "src/**/*.tsx",
      "src/**/*.ts",
      "src/**/*.jsx",
      "src/**/*.js"
    ],
    "exclude": [
      "node_modules/**",
      "build/**",
      "dist/**",
      "src/i18n/**",
      "src/localized/**",
      "**/*.test.*",
      "**/*.spec.*",
      "src/reportWebVitals.ts",
      "src/setupTests.ts"
    ],
    "extractStrings": true,
    "replaceInline": true,
    "preserveWhitespace": true,
    "preserveJSX": true,
    "minLength": 3,
    "maxLength": 500
  },
  "buckets": {
    "json": {
      "include": ["../backend/translations/[locale].json"],
      "outputDir": "../backend/translations"
    }
  },
  "api": {
    "key": "api_ikb8dilr97l4pt5hjnq0bunm",
    "endpoint": "https://api.lingo.dev/v1"
  },
  "automation": {
    "enabled": true,
    "watchMode": true,
    "autoTranslate": true,
    "batchSize": 50
  },
  "translation": {
    "quality": "high",
    "context": "software_ui",
    "tone": "professional",
    "preserveFormatting": true,
    "preservePlaceholders": true
  }
}
